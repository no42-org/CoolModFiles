# Generated by autotools when scripts/build-tfmx-wasm.sh runs. Upstream
# expects developers to regenerate these from configure.ac + Makefile.am
# via build.sh; we follow the same convention, so none of these files
# belong in the repo.

# autoconf / automake / libtool output (top-level)
/aclocal.m4
/autom4te.cache/
/compile
/config.guess
/config.log
/config.status
/config.sub
/configure
/configure~
/depcomp
/install-sh
/libtfmxaudiodecoder.pc
/libtool
/ltmain.sh
/Makefile
/Makefile.in
/missing
/stamp-h1

# libtoolize copies these into m4/; the directory itself is not in upstream
/m4/libtool.m4
/m4/lt~obsolete.m4
/m4/ltoptions.m4
/m4/ltsugar.m4
/m4/ltversion.m4

# make output, anywhere
**/.deps/
**/.libs/
**/Makefile
**/Makefile.in
**/*.o
**/*.lo
**/*.la
**/*.a
**/*.so
**/*.dylib

# autoheader / config.h output (note: src/Config.h.in IS upstream-tracked
# because their convention is to commit the autoheader output; we follow
# the same convention for vendoring fidelity)
src/Config.h
src/Config.h.in~
src/stamp-h1

# stray test artifacts from manual emcc invocations
/a.wasm
/a.out
/a.js
