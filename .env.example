# GitHub personal access token (public_repo scope is sufficient).
# Used at runtime to fetch HELP.md from the upstream orhun/CoolModFiles
# repo via the GitHub GraphQL API.
GITHUB_TOKEN=

# Public-facing domain — used in embed iframe URLs and Twitter share links.
# Production: https://mods.amiga.fans
# Local dev:  http://localhost:3000
DOMAIN=

# Optional: absolute path inside the container/server to a directory of MOD
# files. When set, the player exposes a "Library" tab that browses, searches,
# and plays files from this directory. When unset, the tab is hidden.
#
# Local dev (with ./mods folder in repo root, picked up automatically by `make run`):
#   LIBRARY_ROOT=/library
# Production (Docker):
#   docker run -v /home/you/mods:/library:ro -e LIBRARY_ROOT=/library ...
# LIBRARY_ROOT=
